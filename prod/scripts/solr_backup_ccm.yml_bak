apiVersion: batch/v1
kind: CronJob
metadata:
  name: solr-backup-ccm-daily
spec:
  schedule: "0 23 * * *"
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 3
  jobTemplate:
    spec:
      template:
        spec:
          containers:
          - name: solr-backup-ccm-daily
            image: curlimages/curl:latest
            imagePullPolicy: IfNotPresent
            command:
              - /bin/sh
              - -ec
              - >
                  set -e ;
                  CURRENT_TIME=$(TZ=Europe/Berlin date +%y-%m-%d_%H-%M);
                  curl
                  -u solr-p-admin:-OtZqh2TwFSmUkY2vFVL_Gc33YcWzk2OdVsY4yGHxm
                  https://solr-p-thuega.level-365.com/solr/admin/collections\?action=BACKUP\&name=ccm.$CURRENT_TIME\&collection=ccm\&location=/var/solr/data/backup/ccm\&maxNumBackupPoints=7
          restartPolicy: OnFailure